# Copy to .env and fill in. .env is gitignored — never commit it.

# Auth0 refresh token, extracted ONCE from the logged-in MPP web app.
# In the browser at https://mpp.football (logged in), open DevTools > Console and run:
#
#   copy(Object.values(localStorage)
#     .map(v => { try { return JSON.parse(v) } catch { return null } })
#     .find(o => o && o.body && o.body.refresh_token).body.refresh_token)
#
# Then paste the clipboard value here (it's ~90 chars). Keep it secret.
MPP_REFRESH_TOKEN=

# --- The values below are already known; override only if they change. ---
MPP_AUTH0_DOMAIN=https://connect.ligue1.fr
MPP_AUTH0_CLIENT_ID=grX5jWGWWQ4Uq91oe7KPNDZ96FS3jr0X
MPP_AUTH0_AUDIENCE=https://mpp.ligue1.fr
MPP_API_BASE=https://api.mpp.football
